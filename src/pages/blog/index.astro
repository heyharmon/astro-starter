---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Blog"
  description="Ideas, updates, and lessons learned from our team."
>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-6 py-24 sm:py-32">
    <h1>Blog</h1>
    <p class="mt-6 max-w-2xl text-lg text-neutral-500">
      Thoughts, insights, and updates from our team.
    </p>
  </section>

  <!-- Post listing -->
  <section class="mx-auto max-w-5xl px-6 pb-24">
    {
      posts.length === 0 ? (
        <p class="text-neutral-500">No posts yet. Check back soon.</p>
      ) : (
        <div class="divide-y divide-neutral-200">
          {posts.map((post) => (
            <article class="py-8 first:pt-0 last:pb-0">
              <a
                href={`/blog/${post.id}`}
                class="group block no-underline"
              >
                <div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between">
                  <h2 class="text-xl font-medium transition-colors group-hover:text-neutral-600">
                    {post.data.title}
                  </h2>
                  <time
                    datetime={post.data.date.toISOString()}
                    class="shrink-0 text-sm text-neutral-400"
                  >
                    {post.data.date.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                </div>
                <p class="mt-2 text-sm text-neutral-500">
                  {post.data.description}
                </p>
                {post.data.tags.length > 0 && (
                  <div class="mt-3 flex gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs text-neutral-600">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            </article>
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
