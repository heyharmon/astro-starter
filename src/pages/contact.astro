---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.vue";
import { getEntry, render } from "astro:content";
import siteMeta from "../data/site-meta.json";

const page = await getEntry("pages", "contact");
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-6 py-24 sm:py-32">
    <h1>{page.data.headline}</h1>
    {page.data.subheadline && (
      <p class="mt-6 max-w-2xl text-lg text-neutral-500">
        {page.data.subheadline}
      </p>
    )}
  </section>

  <!-- Contact Content + Form -->
  <section class="border-t border-neutral-200 bg-neutral-50">
    <div class="mx-auto max-w-5xl px-6 py-24 sm:py-32">
      <div class="grid gap-16 lg:grid-cols-2">
        <div class="prose">
          <Content />
        </div>
        <div>
          <ContactForm client:idle formspreeId={siteMeta.formspreeId} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
