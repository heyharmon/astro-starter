---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry, render } from "astro:content";

const page = await getEntry("pages", "home");
const { Content } = await render(page);

const features = [
  {
    title: "Tailored Solutions",
    description:
      "No cookie-cutter approaches. Everything we deliver is built around your specific goals, challenges, and timeline.",
  },
  {
    title: "Transparent Process",
    description:
      "You'll always know where things stand. Regular updates, clear milestones, and no surprises along the way.",
  },
  {
    title: "Proven Results",
    description:
      "We measure success by outcomes, not activity. Every engagement is focused on delivering measurable value.",
  },
  {
    title: "Dedicated Team",
    description:
      "Work directly with the people doing the work — no hand-offs, no layers, no runaround.",
  },
  {
    title: "Flexible Engagement",
    description:
      "Whether you need a one-time project or an ongoing partnership, we adapt to the way you work.",
  },
  {
    title: "Long-Term Support",
    description:
      "We don't disappear after delivery. Ongoing support and guidance to keep things running smoothly.",
  },
];
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-6 py-24 sm:py-32 lg:py-40">
    <div class="flex flex-col items-start">
      <h1 class="max-w-3xl">{page.data.headline}</h1>
      {
        page.data.subheadline && (
          <p class="mt-6 max-w-2xl text-lg leading-8 text-neutral-500">
            {page.data.subheadline}
          </p>
        )
      }
      <div class="mt-10 flex gap-4">
        <a
          href="/contact"
          class="inline-flex items-center rounded-lg bg-neutral-950 px-5 py-2.5 text-sm font-medium text-white no-underline transition-colors hover:bg-neutral-800"
        >
          Get started
        </a>
        <a
          href="/about"
          class="inline-flex items-center rounded-lg border border-neutral-200 bg-white px-5 py-2.5 text-sm font-medium text-neutral-700 no-underline transition-colors hover:bg-neutral-50"
        >
          Learn more
        </a>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="border-t border-neutral-100 bg-neutral-50/50">
    <div class="mx-auto max-w-5xl px-6 py-24 sm:py-32">
      <div class="mb-12">
        <p class="text-sm font-medium uppercase tracking-wider text-accent-600">
          Why work with us
        </p>
        <h2 class="mt-2">What sets us apart</h2>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {
          features.map((feature) => (
            <div class="rounded-xl border border-neutral-200 bg-white p-6">
              <h3 class="mb-2 text-sm font-semibold text-neutral-950">
                {feature.title}
              </h3>
              <p class="text-sm leading-relaxed text-neutral-500">
                {feature.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="mx-auto max-w-5xl px-6 py-24">
    <div class="prose">
      <Content />
    </div>
  </section>
</BaseLayout>
