---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry, render } from "astro:content";

const page = await getEntry("pages", "home");
const { Content } = await render(page);

const features = [
  {
    title: "AI Monitor",
    description:
      "Track how your brand appears in responses from ChatGPT, Claude, Perplexity, Gemini, and Google AI Overviews — in real time.",
  },
  {
    title: "Competitor Intelligence",
    description:
      "See how you stack up against competitors in AI-generated recommendations and understand what drives the difference.",
  },
  {
    title: "Visibility Score",
    description:
      "Get a single, actionable metric that quantifies your brand's presence and sentiment across AI platforms.",
  },
  {
    title: "Actionable Insights",
    description:
      "Receive clear recommendations on how to improve your AI visibility based on what's actually driving results.",
  },
  {
    title: "Trend Tracking",
    description:
      "Monitor how your AI visibility changes over time and correlate shifts with your content and marketing efforts.",
  },
  {
    title: "Alert System",
    description:
      "Get notified when there are significant changes to how AI platforms mention or represent your brand.",
  },
];
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-6 py-24 sm:py-32 lg:py-40">
    <div class="flex flex-col items-start">
      <div
        class="mb-6 inline-flex items-center rounded-full border border-neutral-200 bg-neutral-50 px-3 py-1 text-xs font-medium text-neutral-600"
      >
        AI Visibility Intelligence
      </div>
      <h1 class="max-w-3xl">{page.data.headline}</h1>
      {
        page.data.subheadline && (
          <p class="mt-6 max-w-2xl text-lg leading-8 text-neutral-500">
            {page.data.subheadline}
          </p>
        )
      }
      <div class="mt-10 flex gap-4">
        <a
          href="/contact"
          class="inline-flex items-center rounded-lg bg-neutral-950 px-5 py-2.5 text-sm font-medium text-white no-underline transition-colors hover:bg-neutral-800"
        >
          Get early access
        </a>
        <a
          href="/services"
          class="inline-flex items-center rounded-lg border border-neutral-200 bg-white px-5 py-2.5 text-sm font-medium text-neutral-700 no-underline transition-colors hover:bg-neutral-50"
        >
          Learn more
        </a>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="border-t border-neutral-100 bg-neutral-50/50">
    <div class="mx-auto max-w-5xl px-6 py-24 sm:py-32">
      <div class="mb-12">
        <p class="text-sm font-medium uppercase tracking-wider text-accent-600">
          Platform
        </p>
        <h2 class="mt-2">Everything you need to own your AI presence</h2>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {
          features.map((feature) => (
            <div class="rounded-xl border border-neutral-200 bg-white p-6">
              <h3 class="mb-2 text-sm font-semibold text-neutral-950">
                {feature.title}
              </h3>
              <p class="text-sm leading-relaxed text-neutral-500">
                {feature.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="mx-auto max-w-5xl px-6 py-24">
    <div class="prose">
      <Content />
    </div>
  </section>
</BaseLayout>
