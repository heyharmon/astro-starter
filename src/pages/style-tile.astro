---
/**
 * Style Tile — Design System Preview
 *
 * Development-only page for reviewing the visual design system.
 * Not included in navigation. Renders all design atoms and component patterns
 * using the same tokens and styles as the live site.
 *
 * Inspired by: The Little Campus (littlecampus.ca)
 * Aesthetic: Warm, premium, nurturing, modern
 *
 * Layer 1: Atomic tokens (colors, typography, buttons, forms, effects)
 * Layer 2: Component patterns (hero, cards, CTA, sections, nav, footer)
 *
 * Agents: When adding new component patterns during page building,
 * append a new section above the "NEW PATTERNS BELOW" comment at the bottom.
 */
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Style Tile — Design System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400;1,9..40,500&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- ============================================ -->
    <!-- LAYER 1: ATOMIC TOKENS                       -->
    <!-- ============================================ -->

    <div class="mx-auto max-w-6xl px-6 py-16">
      <span class="section-label mb-4">Style Tile</span>
      <h1 class="mt-4">Design System</h1>
      <p class="mt-6 max-w-2xl text-lg">
        This page previews all design tokens and component patterns used across the site.
        Inspired by <em>The Little Campus</em> — warm, premium, nurturing, modern.
      </p>
    </div>

    <!-- COLORS -->
    <section class="bg-lavender-50">
      <div class="mx-auto max-w-6xl px-6 py-16">
        <span class="section-label mb-4">Layer 1</span>
        <h2 class="mt-4 mb-12">Color Palette</h2>

        <h3 class="mb-6">Gold Accent</h3>
        <div class="grid grid-cols-5 sm:grid-cols-10 gap-2 mb-12">
          <div>
            <div class="h-16 rounded-lg bg-gold-50"></div>
            <p class="mt-2 text-xs text-neutral-500">50</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-gold-100"></div>
            <p class="mt-2 text-xs text-neutral-500">100</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-gold-200"></div>
            <p class="mt-2 text-xs text-neutral-500">200</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-gold-300"></div>
            <p class="mt-2 text-xs text-neutral-500">300</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-gold-400"></div>
            <p class="mt-2 text-xs text-neutral-500">400</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-gold-500"></div>
            <p class="mt-2 text-xs text-neutral-500">500</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-gold-600"></div>
            <p class="mt-2 text-xs text-neutral-500">600</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-gold-700"></div>
            <p class="mt-2 text-xs text-neutral-500">700</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-gold-800"></div>
            <p class="mt-2 text-xs text-neutral-500">800</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-gold-900"></div>
            <p class="mt-2 text-xs text-neutral-500">900</p>
          </div>
        </div>

        <h3 class="mb-6">Lavender Scale</h3>
        <div class="grid grid-cols-5 sm:grid-cols-10 gap-2 mb-12">
          <div>
            <div class="h-16 rounded-lg bg-lavender-50"></div>
            <p class="mt-2 text-xs text-neutral-500">50</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-lavender-100"></div>
            <p class="mt-2 text-xs text-neutral-500">100</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-lavender-200"></div>
            <p class="mt-2 text-xs text-neutral-500">200</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-lavender-300"></div>
            <p class="mt-2 text-xs text-neutral-500">300</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-lavender-400"></div>
            <p class="mt-2 text-xs text-neutral-500">400</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-lavender-500"></div>
            <p class="mt-2 text-xs text-neutral-500">500</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-lavender-600"></div>
            <p class="mt-2 text-xs text-neutral-500">600</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-lavender-700"></div>
            <p class="mt-2 text-xs text-neutral-500">700</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-lavender-800"></div>
            <p class="mt-2 text-xs text-neutral-500">800</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-lavender-900"></div>
            <p class="mt-2 text-xs text-neutral-500">900</p>
          </div>
        </div>

        <h3 class="mb-6">Pastel Accents</h3>
        <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-12">
          <div>
            <div class="h-16 rounded-lg bg-pastel-lavender"></div>
            <p class="mt-2 text-xs text-neutral-500">Lavender</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-pastel-blue"></div>
            <p class="mt-2 text-xs text-neutral-500">Blue</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-pastel-green"></div>
            <p class="mt-2 text-xs text-neutral-500">Green</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-pastel-yellow"></div>
            <p class="mt-2 text-xs text-neutral-500">Yellow</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-pastel-pink"></div>
            <p class="mt-2 text-xs text-neutral-500">Pink</p>
          </div>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-12">
          <div>
            <div class="h-16 rounded-lg bg-pastel-lavender-light"></div>
            <p class="mt-2 text-xs text-neutral-500">Lavender Light</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-pastel-blue-light"></div>
            <p class="mt-2 text-xs text-neutral-500">Blue Light</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-pastel-green-light"></div>
            <p class="mt-2 text-xs text-neutral-500">Green Light</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-pastel-yellow-light"></div>
            <p class="mt-2 text-xs text-neutral-500">Yellow Light</p>
          </div>
          <div>
            <div class="h-16 rounded-lg bg-pastel-pink-light"></div>
            <p class="mt-2 text-xs text-neutral-500">Pink Light</p>
          </div>
        </div>

        <h3 class="mb-6">Section Backgrounds</h3>
        <div class="grid gap-4 sm:grid-cols-3 mb-12">
          <div class="p-6 bg-white rounded-2xl">
            <p class="text-xs text-neutral-500">Primary -- white</p>
          </div>
          <div class="p-6 bg-lavender-50 rounded-2xl">
            <p class="text-xs text-neutral-500">Secondary -- lavender-50</p>
          </div>
          <div class="p-6 bg-gradient-to-br from-lavender-100 to-sky-50 rounded-2xl">
            <p class="text-xs text-neutral-500">Gradient -- lavender-100 to sky-50</p>
          </div>
        </div>

        <h3 class="mb-6">Text Colors</h3>
        <div class="space-y-3">
          <p class="text-neutral-950 font-sans font-medium">Primary -- neutral-950 (#111)</p>
          <p class="text-neutral-900">Body -- neutral-900 (#222)</p>
          <p class="text-neutral-600">Muted -- neutral-600</p>
          <p class="text-neutral-500">Subtle -- neutral-500</p>
          <p class="text-lavender-800 font-sans font-medium">Accent -- lavender-800 (#2C0E8C)</p>
        </div>
      </div>
    </section>

    <!-- TYPOGRAPHY -->
    <section class="mx-auto max-w-6xl px-6 py-16">
      <h2 class="mb-12">Typography</h2>

      <div class="space-y-10 mb-12">
        <div>
          <p class="text-xs text-neutral-500 mb-2">H1 -- DM Sans / font-normal / text-5xl sm:text-6xl lg:text-7xl</p>
          <h1>Where every child thrives</h1>
        </div>
        <div>
          <p class="text-xs text-neutral-500 mb-2">H2 -- DM Sans / font-normal / text-3xl sm:text-4xl</p>
          <h2>The foundation for learning and growth</h2>
        </div>
        <div>
          <p class="text-xs text-neutral-500 mb-2">H3 -- DM Sans / font-medium / text-xl sm:text-2xl</p>
          <h3>A nurturing environment for early education</h3>
        </div>
      </div>

      <div class="space-y-8 max-w-2xl">
        <div>
          <p class="text-xs text-neutral-500 mb-2">Body -- Lora (serif) / text-neutral-900</p>
          <p>We believe that every child deserves <em>the foundation for learning, confidence, and emotional well-being</em>. Our approach combines warmth with structure, creating spaces where curiosity flourishes naturally.</p>
        </div>
        <div>
          <p class="text-xs text-neutral-500 mb-2">Section Label -- pill badge (section-label class)</p>
          <span class="section-label">Our Programs</span>
        </div>
        <div>
          <p class="text-xs text-neutral-500 mb-2">Pastel Badges -- category/pillar labels</p>
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full bg-pastel-lavender-light px-3 py-1 text-xs font-sans font-medium text-neutral-800">Social Skills</span>
            <span class="rounded-full bg-pastel-blue-light px-3 py-1 text-xs font-sans font-medium text-neutral-800">Creativity</span>
            <span class="rounded-full bg-pastel-green-light px-3 py-1 text-xs font-sans font-medium text-neutral-800">Nature</span>
            <span class="rounded-full bg-pastel-yellow-light px-3 py-1 text-xs font-sans font-medium text-neutral-800">Play-Based</span>
            <span class="rounded-full bg-pastel-pink-light px-3 py-1 text-xs font-sans font-medium text-neutral-800">Emotional</span>
          </div>
        </div>
        <div>
          <p class="text-xs text-neutral-500 mb-2">Link -- lavender-800 with hover underline</p>
          <a href="#0">This is a text link with hover underline</a>
        </div>
      </div>
    </section>

    <!-- BUTTONS -->
    <section class="bg-lavender-50">
      <div class="mx-auto max-w-6xl px-6 py-16">
        <h2 class="mb-12">Buttons</h2>

        <div class="flex flex-wrap gap-6 items-center mb-8">
          <a href="#0" class="btn-primary">Gold Primary</a>
          <a href="#0" class="btn-secondary">Dark Secondary</a>
          <a href="#0" class="btn-ghost">Ghost Outline</a>
        </div>
        <div class="flex flex-wrap gap-6 items-center">
          <a href="#0" class="btn-primary opacity-50 pointer-events-none">Primary Disabled</a>
          <a href="#0" class="btn-secondary opacity-50 pointer-events-none">Secondary Disabled</a>
          <a href="#0" class="btn-ghost opacity-50 pointer-events-none">Ghost Disabled</a>
        </div>
      </div>
    </section>

    <!-- FORM INPUTS -->
    <section class="mx-auto max-w-6xl px-6 py-16">
      <h2 class="mb-12">Form Inputs</h2>

      <div class="max-w-md space-y-6">
        <div>
          <label class="mb-2 block text-sm font-sans font-medium text-neutral-950">Text Input</label>
          <input
            type="text"
            placeholder="Placeholder text"
            class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-3.5 font-serif text-neutral-900 placeholder-neutral-400 focus:border-lavender-400 focus:outline-none focus:ring-1 focus:ring-lavender-400"
          />
        </div>
        <div>
          <label class="mb-2 block text-sm font-sans font-medium text-neutral-950">Textarea</label>
          <textarea
            rows="4"
            placeholder="Placeholder text"
            class="w-full rounded-xl border border-neutral-300 bg-white px-4 py-3.5 font-serif text-neutral-900 placeholder-neutral-400 focus:border-lavender-400 focus:outline-none focus:ring-1 focus:ring-lavender-400"
          ></textarea>
        </div>
        <button type="button" class="btn-primary">Submit</button>
      </div>
    </section>

    <!-- BORDERS & EFFECTS -->
    <section class="bg-lavender-50">
      <div class="mx-auto max-w-6xl px-6 py-16">
        <h2 class="mb-12">Cards & Effects</h2>

        <div class="space-y-8">
          <div>
            <p class="text-xs text-neutral-500 mb-3">Flat card -- rounded-2xl, white bg, NO border (sits on colored bg)</p>
            <div class="rounded-2xl bg-white p-8">
              <p class="text-sm">Card with no border -- relies on background contrast for definition.</p>
            </div>
          </div>
          <div>
            <p class="text-xs text-neutral-500 mb-3">Card with subtle shadow -- rounded-2xl shadow-sm</p>
            <div class="rounded-2xl bg-white p-8 shadow-sm">
              <p class="text-sm">Card with subtle shadow for slight elevation.</p>
            </div>
          </div>
          <div>
            <p class="text-xs text-neutral-500 mb-3">Image rounding -- rounded-2xl to rounded-3xl</p>
            <div class="grid grid-cols-2 gap-4 max-w-sm">
              <div class="aspect-square rounded-2xl bg-neutral-200 overflow-hidden">
                <img src="/images/placeholders/square-1x1.svg" alt="Placeholder" class="h-full w-full object-cover" />
              </div>
              <div class="aspect-square rounded-3xl bg-neutral-200 overflow-hidden">
                <img src="/images/placeholders/square-1x1.svg" alt="Placeholder" class="h-full w-full object-cover" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- LAYER 2: COMPONENT PATTERNS                  -->
    <!-- ============================================ -->

    <div class="mx-auto max-w-6xl px-6 py-16">
      <span class="section-label mb-4">Layer 2</span>
      <h2 class="mt-4">Component Patterns</h2>
      <p class="mt-4 max-w-2xl text-lg">Reusable section patterns used across the site. This section grows as new page layouts introduce new patterns.</p>
    </div>

    <!-- PATTERN: hero-image -->
    <section class="relative bg-neutral-200 overflow-hidden">
      <div class="mx-auto max-w-6xl px-6 py-32 sm:py-40">
        <p class="text-xs text-neutral-500 mb-4 font-sans">PATTERN: hero-image</p>
        <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
          <div>
            <h1>Where Every Child Thrives</h1>
          </div>
          <div>
            <p class="text-lg">
              We provide <em>the foundation for learning, confidence, and emotional well-being</em> in a warm, nurturing environment.
            </p>
            <div class="mt-8 flex gap-4">
              <a href="#0" class="btn-primary">Book a Tour</a>
              <a href="#0" class="btn-ghost">Learn More</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PATTERN: section-label -->
    <section class="mx-auto max-w-6xl px-6 py-24">
      <p class="text-xs text-neutral-500 mb-4 font-sans">PATTERN: section-label</p>
      <span class="section-label mb-6">Our Approach</span>
      <h2 class="mt-4 max-w-2xl">Built on the pillars of early childhood development</h2>
      <p class="mt-4 max-w-xl">
        Each pillar represents a core area of growth that we nurture through play-based learning and intentional programming.
      </p>
    </section>

    <!-- PATTERN: card-feature -->
    <section class="bg-gradient-to-br from-lavender-100 to-sky-50">
      <div class="mx-auto max-w-6xl px-6 py-24">
        <p class="text-xs text-neutral-500 mb-4 font-sans">PATTERN: card-feature (on gradient background)</p>
        <h2 class="mb-8">Our Pillars</h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-2xl bg-white p-8">
            <span class="rounded-full bg-pastel-lavender-light px-3 py-1 text-xs font-sans font-medium text-neutral-800">Social</span>
            <h3 class="mt-5">Social & Emotional</h3>
            <p class="mt-3 text-sm">Building confidence, empathy, and the ability to navigate relationships with peers and adults.</p>
          </div>
          <div class="rounded-2xl bg-white p-8">
            <span class="rounded-full bg-pastel-blue-light px-3 py-1 text-xs font-sans font-medium text-neutral-800">Creative</span>
            <h3 class="mt-5">Creativity & Expression</h3>
            <p class="mt-3 text-sm">Encouraging imagination through art, music, dramatic play, and open-ended exploration.</p>
          </div>
          <div class="rounded-2xl bg-white p-8">
            <span class="rounded-full bg-pastel-green-light px-3 py-1 text-xs font-sans font-medium text-neutral-800">Nature</span>
            <h3 class="mt-5">Nature & Environment</h3>
            <p class="mt-3 text-sm">Connecting children with the natural world through outdoor play and environmental awareness.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PATTERN: testimonial-card -->
    <section class="bg-lavender-50">
      <div class="mx-auto max-w-6xl px-6 py-24">
        <p class="text-xs text-neutral-500 mb-4 font-sans">PATTERN: testimonial-card</p>
        <span class="section-label mb-4">Testimonials</span>
        <h2 class="mt-4 mb-10">What families say</h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-2xl bg-white p-8">
            <div class="text-4xl text-lavender-200 font-serif leading-none">"</div>
            <p class="mt-2 text-sm italic">
              Our daughter has blossomed since starting here. The teachers are so nurturing and attentive. We couldn't be happier with the care she receives every day.
            </p>
            <div class="mt-6 flex items-center gap-3">
              <div class="h-8 w-8 rounded-full bg-pastel-lavender-light"></div>
              <div>
                <p class="text-sm font-sans font-medium text-neutral-950">Sarah M.</p>
                <p class="text-xs text-neutral-500">Google Reviews</p>
              </div>
            </div>
          </div>
          <div class="rounded-2xl bg-white p-8">
            <div class="text-4xl text-lavender-200 font-serif leading-none">"</div>
            <p class="mt-2 text-sm italic">
              The curriculum is thoughtful and the environment is incredibly warm. Our son looks forward to going every single morning.
            </p>
            <div class="mt-6 flex items-center gap-3">
              <div class="h-8 w-8 rounded-full bg-pastel-blue-light"></div>
              <div>
                <p class="text-sm font-sans font-medium text-neutral-950">Michael T.</p>
                <p class="text-xs text-neutral-500">Google Reviews</p>
              </div>
            </div>
          </div>
          <div class="rounded-2xl bg-white p-8">
            <div class="text-4xl text-lavender-200 font-serif leading-none">"</div>
            <p class="mt-2 text-sm italic">
              From the moment we walked in, we knew this was the right place. The staff genuinely cares about each child's development and happiness.
            </p>
            <div class="mt-6 flex items-center gap-3">
              <div class="h-8 w-8 rounded-full bg-pastel-green-light"></div>
              <div>
                <p class="text-sm font-sans font-medium text-neutral-950">Jessica L.</p>
                <p class="text-xs text-neutral-500">Google Reviews</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PATTERN: cta-split -->
    <section class="mx-auto max-w-6xl px-6 py-24">
      <p class="text-xs text-neutral-500 mb-4 font-sans">PATTERN: cta-split</p>
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div class="aspect-[4/3] overflow-hidden rounded-2xl bg-neutral-200">
          <img
            src="/images/placeholders/landscape-4x3.svg"
            alt="Placeholder"
            class="h-full w-full object-cover"
          />
        </div>
        <div>
          <span class="section-label mb-4">Enrolment</span>
          <h2 class="mt-4">Begin your child's journey with us</h2>
          <p class="mt-4">
            We welcome families to visit our campus and experience the warmth and care firsthand. Book a tour to see our programs in action.
          </p>
          <a href="#0" class="btn-primary mt-8">Book a Tour</a>
        </div>
      </div>
    </section>

    <!-- PATTERN: section-2col-narrative -->
    <section class="bg-lavender-50">
      <div class="mx-auto max-w-6xl px-6 py-24">
        <p class="text-xs text-neutral-500 mb-4 font-sans">PATTERN: section-2col-narrative</p>
        <div class="grid gap-12 lg:grid-cols-5 lg:items-start">
          <div class="lg:col-span-2">
            <span class="section-label mb-4">Our Story</span>
            <h2 class="mt-4">Founded on a vision for nurturing excellence</h2>
          </div>
          <div class="lg:col-span-3">
            <p class="text-lg">
              What began as a dream to create <em>something truly special</em> for young learners has grown into a community built on trust, warmth, and an unwavering commitment to early childhood development.
            </p>
            <p class="mt-4">
              Our approach is rooted in the belief that every child is capable, curious, and full of potential. We create environments where children feel safe to explore, ask questions, and develop the confidence they need to thrive.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- PATTERN: section-alternating-bg -->
    <section class="bg-white">
      <div class="mx-auto max-w-6xl px-6 py-24">
        <p class="text-xs text-neutral-500 mb-4 font-sans">PATTERN: section-alternating-bg</p>
        <h2 class="mb-4">Background Transitions</h2>
        <p class="max-w-2xl">
          Sections alternate between white, lavender-50, and gradient backgrounds. No border dividers -- background color transitions provide visual separation between sections.
        </p>
      </div>
    </section>

    <!-- PATTERN: nav-preview -->
    <section class="mx-auto max-w-6xl px-6 py-24">
      <p class="text-xs text-neutral-500 mb-4 font-sans">PATTERN: nav-preview</p>
      <h2 class="mb-8">Navigation</h2>
      <div class="rounded-2xl bg-white shadow-sm">
        <nav class="flex items-center justify-between px-6 py-4">
          <a href="#0" class="text-lg font-sans font-medium tracking-tight text-lavender-800 no-underline">
            Site Name
          </a>
          <ul class="flex items-center gap-6">
            <li><a href="#0" class="text-sm font-sans font-medium text-neutral-950 no-underline">Active</a></li>
            <li><a href="#0" class="text-sm font-sans font-medium text-neutral-600 no-underline hover:text-neutral-950">Link</a></li>
            <li><a href="#0" class="text-sm font-sans font-medium text-neutral-600 no-underline hover:text-neutral-950">Link</a></li>
            <li><a href="#0" class="btn-primary !py-2 !px-4 text-sm">Contact</a></li>
          </ul>
        </nav>
