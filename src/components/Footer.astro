---
import footerLinks from "../data/footer.json";
import siteMeta from "../data/site-meta.json";

const socialLinks = Object.entries(siteMeta.social).filter(([_, url]) => url);
---

<footer class="border-t border-neutral-200 bg-neutral-50">
  <div class="mx-auto max-w-5xl px-6 py-12">
    {
      footerLinks.length > 0 && (
        <div class="mb-10 grid grid-cols-2 gap-8 sm:grid-cols-3 lg:grid-cols-4">
          {footerLinks.map((group) => (
            <div>
              <h4 class="text-sm font-semibold text-neutral-900">
                {group.section}
              </h4>
              <ul class="mt-4 space-y-2">
                {group.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="text-sm text-neutral-500 no-underline transition-colors hover:text-neutral-900"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )
    }

    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
      <div>
        <p class="text-sm text-neutral-500">{siteMeta.copyright}</p>
      </div>

      {
        socialLinks.length > 0 && (
          <div class="flex items-center gap-6">
            {socialLinks.map(([platform, url]) => (
              <a
                href={url as string}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm capitalize text-neutral-500 no-underline transition-colors hover:text-neutral-900"
              >
                {platform}
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>
</footer>
